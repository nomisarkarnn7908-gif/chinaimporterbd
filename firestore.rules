rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "nomisarkarnn7908@gmail.com")
        );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             (!('walletBalance' in data) || data.walletBalance is number) &&
             (!('heldBalance' in data) || data.heldBalance is number);
    }

    function isValidOrder(data) {
      return hasRequiredFields(['userId', 'totalAmount', 'orderStatus']) &&
             data.userId is string &&
             data.totalAmount is number &&
             data.orderStatus is string;
    }

    function isValidWithdrawal(data) {
      return hasRequiredFields(['userId', 'amount', 'method', 'status']) &&
             data.userId is string &&
             data.amount is number &&
             data.method in ['bkash', 'nagad', 'bank'] &&
             data.status in ['pending', 'completed', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                      isValidUser(request.resource.data) && 
                      (
                        (isOwner(userId) && request.resource.data.role == 'user') || 
                        (request.auth.token.email == "nomisarkarnn7908@gmail.com" && isOwner(userId))
                      );
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // Product catalog
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Wallet transactions
    match /wallet_transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Withdrawal requests
    match /withdrawal_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
